<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd" id="Definitions_HTTPS_to_SFTP_Template" targetNamespace="http://sap.com/xi/IntegrationFlow">
  <bpmn2:collaboration id="Collaboration_HTTPS_to_SFTP" name="HTTPS to SFTP">
    <bpmn2:extensionElements>
      <ifl:property><key>namespaceMapping</key><value/></ifl:property>
      <ifl:property><key>allowedHeaderList</key><value>SapAuthenticatedUserName|CamelHttpPath|CamelHttpUrl|CamelFileName</value></ifl:property>
      <ifl:property><key>httpSessionHandling</key><value>onIntegrationFlow</value></ifl:property>
      <ifl:property><key>ServerTrace</key><value>false</value></ifl:property>
      <ifl:property><key>returnExceptionToSender</key><value>false</value></ifl:property>
      <ifl:property><key>log</key><value>All events</value></ifl:property>
      <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
      <ifl:property><key>cmdVariantUri</key><value>ctype::IFlowVariant/cname::IFlowConfiguration/version::1.1.15</value></ifl:property>
    </bpmn2:extensionElements>
    <bpmn2:participant id="Participant_Sender" ifl:type="EndpointSender" name="HTTPS Sender">
      <bpmn2:extensionElements>
        <ifl:property><key>enableBasicAuthentication</key><value>false</value></ifl:property>
        <ifl:property><key>ifl:type</key><value>EndpointSender</value></ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>
    <bpmn2:participant id="Participant_Receiver" ifl:type="EndpointRecevier" name="SFTP Receiver">
      <bpmn2:extensionElements>
        <ifl:property><key>ifl:type</key><value>EndpointRecevier</value></ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>
    <bpmn2:participant id="Participant_Process" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process_HTTPS_to_SFTP">
      <bpmn2:extensionElements/>
    </bpmn2:participant>
    <bpmn2:messageFlow id="MessageFlow_HTTPS_Inbound" name="HTTPS" sourceRef="Participant_Sender" targetRef="StartEvent_Inbound">
      <bpmn2:extensionElements>
        <ifl:property><key>ComponentType</key><value>HTTPS</value></ifl:property>
        <ifl:property><key>componentVersion</key><value>1.3</value></ifl:property>
        <ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::sap:HTTPS/tp::HTTPS/mp::None/direction::Sender/version::1.3.0</value></ifl:property>
        <ifl:property><key>direction</key><value>Sender</value></ifl:property>
        <ifl:property><key>MessageProtocol</key><value>None</value></ifl:property>
        <ifl:property><key>TransportProtocol</key><value>HTTPS</value></ifl:property>
        <ifl:property><key>address</key><value>{{HTTPS_ENDPOINT_PATH}}</value></ifl:property>
        <ifl:property><key>authorization</key><value>User Role</value></ifl:property>
        <ifl:property><key>csrfProtected</key><value>false</value></ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:messageFlow>
    <bpmn2:messageFlow id="MessageFlow_SFTP_Outbound" name="SFTP" sourceRef="ServiceTask_Send_To_SFTP" targetRef="Participant_Receiver">
      <bpmn2:extensionElements>
        <ifl:property><key>ComponentType</key><value>SFTP</value></ifl:property>
        <ifl:property><key>componentVersion</key><value>1.14</value></ifl:property>
        <ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::None/direction::Receiver/version::1.14.0</value></ifl:property>
        <ifl:property><key>direction</key><value>Receiver</value></ifl:property>
        <ifl:property><key>MessageProtocol</key><value>None</value></ifl:property>
        <ifl:property><key>TransportProtocol</key><value>SFTP</value></ifl:property>
        <ifl:property><key>host</key><value>{{SFTP_HOST}}</value></ifl:property>
        <ifl:property><key>port</key><value>{{SFTP_PORT}}</value></ifl:property>
        <ifl:property><key>directory</key><value>{{SFTP_DIRECTORY}}</value></ifl:property>
        <ifl:property><key>fileName</key><value>{{SFTP_FILENAME}}</value></ifl:property>
        <ifl:property><key>authentication</key><value>Public Key</value></ifl:property>
        <ifl:property><key>credentialName</key><value>{{SFTP_CREDENTIAL_ALIAS}}</value></ifl:property>
        <ifl:property><key>proxyType</key><value>Internet</value></ifl:property>
        <ifl:property><key>useTempFileName</key><value>true</value></ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:messageFlow>
  </bpmn2:collaboration>
  <bpmn2:process id="Process_HTTPS_to_SFTP" name="Integration Process" isExecutable="true">
    <bpmn2:extensionElements>
      <ifl:property><key>transactionTimeout</key><value>30</value></ifl:property>
      <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
      <ifl:property><key>cmdVariantUri</key><value>ctype::FlowElementVariant/cname::IntegrationProcess/version::1.1.3</value></ifl:property>
    </bpmn2:extensionElements>
    <bpmn2:startEvent id="StartEvent_Inbound" name="HTTPS Request">
      <bpmn2:extensionElements>
        <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:outgoing>SequenceFlow_Start_To_Send</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:serviceTask id="ServiceTask_Send_To_SFTP" name="Send to SFTP">
      <bpmn2:extensionElements>
        <ifl:property><key>ActivityType</key><value>ExternalCall</value></ifl:property>
        <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::ExternalCall/version::1.0.4</value></ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SequenceFlow_Start_To_Send</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_Send_To_End</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:endEvent id="EndEvent_Done" name="Completed">
      <bpmn2:extensionElements>
        <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SequenceFlow_Send_To_End</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SequenceFlow_Start_To_Send" sourceRef="StartEvent_Inbound" targetRef="ServiceTask_Send_To_SFTP"/>
    <bpmn2:sequenceFlow id="SequenceFlow_Send_To_End" sourceRef="ServiceTask_Send_To_SFTP" targetRef="EndEvent_Done"/>
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_HTTPS_to_SFTP">
    <bpmndi:BPMNPlane id="BPMNPlane_HTTPS_to_SFTP" bpmnElement="Collaboration_HTTPS_to_SFTP">
      <bpmndi:BPMNShape id="Shape_Sender" bpmnElement="Participant_Sender">
        <dc:Bounds x="80" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Process" bpmnElement="Participant_Process">
        <dc:Bounds x="250" y="80" width="480" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Receiver" bpmnElement="Participant_Receiver">
        <dc:Bounds x="790" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_Inbound">
        <dc:Bounds x="300" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Send" bpmnElement="ServiceTask_Send_To_SFTP">
        <dc:Bounds x="430" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End" bpmnElement="EndEvent_Done">
        <dc:Bounds x="650" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_HTTPS_Inbound" bpmnElement="MessageFlow_HTTPS_Inbound">
        <di:waypoint x="200" y="160"/>
        <di:waypoint x="300" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Start_To_Send" bpmnElement="SequenceFlow_Start_To_Send">
        <di:waypoint x="336" y="160"/>
        <di:waypoint x="430" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Send_To_End" bpmnElement="SequenceFlow_Send_To_End">
        <di:waypoint x="550" y="160"/>
        <di:waypoint x="650" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SFTP_Outbound" bpmnElement="MessageFlow_SFTP_Outbound">
        <di:waypoint x="550" y="160"/>
        <di:waypoint x="790" y="160"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
